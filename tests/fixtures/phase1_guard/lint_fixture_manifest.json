{
  "version": "1.0",
  "description": "Reproducible fixture set for phase1 guard category-profile lint checks.",
  "cases": [
    {
      "case_id": "lint_valid_config",
      "description": "Valid category profile config should pass lint.",
      "config_path": "tests/fixtures/phase1_guard/lint/valid/phase1_guard_category_profiles_valid.json",
      "expected_exit_code": 0,
      "recommended_command": "python run_phase1_guard_category_profile_lint.py --config-path tests/fixtures/phase1_guard/lint/valid/phase1_guard_category_profiles_valid.json",
      "expected_summary_checks": [
        {
          "path": "config_valid",
          "equals": true
        },
        {
          "path": "category_profile_source",
          "equals": "external_config"
        },
        {
          "path": "category_profile_config_loaded",
          "equals": true
        },
        {
          "path": "config_error_code",
          "equals": null
        },
        {
          "path": "source_cli",
          "equals": "run_phase1_guard_category_profile_lint.py"
        },
        {
          "path": "config_path",
          "contains": "tests/fixtures/phase1_guard/lint/valid/phase1_guard_category_profiles_valid.json"
        }
      ]
    },
    {
      "case_id": "lint_missing_config",
      "description": "Missing config path should fail lint with config_missing code.",
      "config_path": "tests/fixtures/phase1_guard/lint/missing/phase1_guard_missing_config.json",
      "expected_exit_code": 1,
      "recommended_command": "python run_phase1_guard_category_profile_lint.py --config-path tests/fixtures/phase1_guard/lint/missing/phase1_guard_missing_config.json",
      "expected_summary_checks": [
        {
          "path": "config_valid",
          "equals": false
        },
        {
          "path": "category_profile_source",
          "equals": "builtin_fallback"
        },
        {
          "path": "config_error_code",
          "contains": "config_missing:"
        }
      ]
    },
    {
      "case_id": "lint_bad_json",
      "description": "Broken JSON should fail lint with config_json_decode_error code.",
      "config_path": "tests/fixtures/phase1_guard/lint/bad_json/phase1_guard_bad_config.json",
      "expected_exit_code": 1,
      "recommended_command": "python run_phase1_guard_category_profile_lint.py --config-path tests/fixtures/phase1_guard/lint/bad_json/phase1_guard_bad_config.json",
      "expected_summary_checks": [
        {
          "path": "config_valid",
          "equals": false
        },
        {
          "path": "category_profile_source",
          "equals": "builtin_fallback"
        },
        {
          "path": "config_error_code",
          "contains": "config_json_decode_error:"
        }
      ]
    },
    {
      "case_id": "lint_bad_schema",
      "description": "Schema type error should fail lint with config_schema_error code.",
      "config_path": "tests/fixtures/phase1_guard/lint/bad_schema/phase1_guard_bad_schema_config.json",
      "expected_exit_code": 1,
      "recommended_command": "python run_phase1_guard_category_profile_lint.py --config-path tests/fixtures/phase1_guard/lint/bad_schema/phase1_guard_bad_schema_config.json",
      "expected_summary_checks": [
        {
          "path": "config_valid",
          "equals": false
        },
        {
          "path": "category_profile_source",
          "equals": "builtin_fallback"
        },
        {
          "path": "config_error_code",
          "contains": "config_schema_error:"
        },
        {
          "path": "config_error_code",
          "contains": "exhibitions_text.required_input_files"
        }
      ]
    }
  ]
}

