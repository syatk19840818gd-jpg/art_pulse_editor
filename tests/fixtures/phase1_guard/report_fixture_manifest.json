          "non_empty": true
        },
        {
          "path": "failed_matrices_count",
          "equals": 0
        },
        {
          "path": "child_summary_paths",
          "non_empty": true
        }
      ]
    },
    {
      "case_name": "report_missing_summary",
      "description": "missing integrated summary should return exit 1",
      "summary_path": "tests/fixtures/phase1_guard/report/missing/phase1_guard_all_matrices_missing.json",
      "policy_expected": "default_report_only",
      "expected_exit_code": 1
    },
    {
      "case_name": "report_bad_json_summary",
      "description": "broken JSON integrated summary should return exit 1",
