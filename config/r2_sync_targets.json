{
  "version": "v1",
  "global_exclude_globs": [
    "**/__pycache__/**",
    "**/*.pyc",
    "**/_trial/**",
    "**/_trash/**",
    "**/*.tmp",
    "**/*.bak*",
    "**/Thumbs.db"
  ],
  "scopes": {
    "enrichment_current_primary": {
      "description": "Primary sync lane for current enrichment canonical artifacts.",
      "enabled_by_default": true,
      "prune_allowed": true,
      "targets": [
        {
          "local_root": "data/current/enrichment",
          "r2_prefix": "data/current/enrichment",
          "include_globs": [
            "**/*"
          ],
          "exclude_globs": []
        }
      ]
    },
    "enrichment_history_audit": {
      "description": "Secondary audit/backup lane for enrichment history artifacts.",
      "enabled_by_default": true,
      "prune_allowed": false,
      "targets": [
        {
          "local_root": "data/history/enrichment/artists",
          "r2_prefix": "data/history/enrichment/artists",
          "include_globs": [
            "**/*"
          ],
          "exclude_globs": []
        },
        {
          "local_root": "data/history/enrichment/exhibitions",
          "r2_prefix": "data/history/enrichment/exhibitions",
          "include_globs": [
            "**/*"
          ],
          "exclude_globs": []
        }
      ]
    },
    "raw_current_primary": {
      "description": "Canonical current lane for raw seed10 artifacts.",
      "enabled_by_default": true,
      "prune_allowed": true,
      "targets": [
        {
          "local_root": "data/current/raw",
          "r2_prefix": "data/current/raw",
          "include_globs": [
            "**/*"
          ],
          "exclude_globs": []
        }
      ]
    },
    "images_metadata_current": {
      "description": "Canonical current lane for image metadata artifacts.",
      "enabled_by_default": true,
      "prune_allowed": true,
      "targets": [
        {
          "local_root": "data/current/images/metadata",
          "r2_prefix": "data/current/images/metadata",
          "include_globs": [
            "**/*"
          ],
          "exclude_globs": []
        }
      ]
    },
    "images_cache_current": {
      "description": "Canonical current lane for image cache artifacts.",
      "enabled_by_default": true,
      "prune_allowed": true,
      "targets": [
        {
          "local_root": "data/current/images/cache",
          "r2_prefix": "data/current/images/cache",
          "include_globs": [
            "**/*"
          ],
          "exclude_globs": []
        }
      ]
    },
    "artists_vector_current": {
      "description": "Canonical current lane for artists vector artifacts.",
      "enabled_by_default": true,
      "prune_allowed": true,
      "targets": [
        {
          "local_root": "data/current/vector/artists",
          "r2_prefix": "data/current/vector/artists",
          "include_globs": [
            "**/*"
          ],
          "exclude_globs": []
        }
      ]
    },
    "current_ledgers_family": {
      "description": "Canonical current lane for formal current ledgers family.",
      "enabled_by_default": false,
      "prune_allowed": true,
      "targets": [
        {
          "local_root": "data/current/ledgers",
          "r2_prefix": "data/current/ledgers",
          "include_globs": [
            "**/*"
          ],
          "exclude_globs": []
        }
      ]
    },
    "artist_works_images_vector_current": {
      "description": "Canonical current lane for ArtWork Search vector artifacts.",
      "enabled_by_default": false,
      "prune_allowed": true,
      "targets": [
        {
          "local_root": "data/current/vector/artist_works_images",
          "r2_prefix": "data/current/vector/artist_works_images",
          "include_globs": [
            "**/*"
          ],
          "exclude_globs": []
        }
      ]
    },
    "phase1_seed10_formal": {
      "description": "Legacy seed10 lane excluding current cache family (fallback assets; not default primary target).",
      "enabled_by_default": false,
      "prune_allowed": false,
      "targets": [
        {
          "local_root": "data/phase1_seed10/derived",
          "r2_prefix": "phase1_seed10/derived",
          "include_globs": [
            "**/*"
          ],
          "exclude_globs": [
            "images/**"
          ]
        }
      ]
    },
    "phase1_seed10_legacy_images_prune": {
      "description": "Prune-only legacy remote residue for old seed10 image cache structure.",
      "enabled_by_default": false,
      "prune_allowed": true,
      "targets": [
        {
          "local_root": "data/phase1_seed10/derived",
          "r2_prefix": "phase1_seed10/derived",
          "include_globs": [
            "images/**"
          ],
          "exclude_globs": []
        }
      ]
    },
    "phase1_seed10_legacy_image_metadata_prune": {
      "description": "Prune-only legacy remote residue for old seed10 image metadata root files.",
      "enabled_by_default": false,
      "prune_allowed": true,
      "targets": [
        {
          "local_root": "data/phase1_seed10/derived",
          "r2_prefix": "phase1_seed10/derived",
          "include_globs": [
            "artist_works_images_*.jsonl",
            "exhibitions_images_*.jsonl"
          ],
          "exclude_globs": []
        }
      ]
    },
    "phase1_seed10_legacy_vector_prune": {
      "description": "Prune-only legacy remote residue for old seed10 vector artifacts.",
      "enabled_by_default": false,
      "prune_allowed": true,
      "targets": [
        {
          "local_root": "data/phase1_seed10/derived",
          "r2_prefix": "phase1_seed10/derived",
          "include_globs": [
            "vector/**"
          ],
          "exclude_globs": []
        }
      ]
    },
    "phase1_seed10_legacy_request_prune": {
      "description": "Prune-only legacy remote residue for old seed10 request artifacts.",
      "enabled_by_default": false,
      "prune_allowed": true,
      "targets": [
        {
          "local_root": "data/phase1_seed10/derived",
          "r2_prefix": "phase1_seed10/derived",
          "include_globs": [
            "artists_enrichment_requests_*.jsonl"
          ],
          "exclude_globs": []
        }
      ]
    },
    "phase1_seed10_source_legacy_prune": {
      "description": "Prune-only legacy remote residue for old seed10 source prefix duplicated by current raw.",
      "enabled_by_default": false,
      "prune_allowed": true,
      "targets": [
        {
          "local_root": "phase1_seed10/source",
          "r2_prefix": "phase1_seed10/source",
          "include_globs": [
            "**/*"
          ],
          "exclude_globs": []
        }
      ]
    },
    "phase1_seed10_derived_manifest_legacy_prune": {
      "description": "Prune-only legacy remote residue for old seed10 artifact manifest prefix.",
      "enabled_by_default": false,
      "prune_allowed": true,
      "targets": [
        {
          "local_root": "phase1_seed10/derived",
          "r2_prefix": "phase1_seed10/derived",
          "include_globs": [
            "phase1_seed10_artifact_manifest.json"
          ],
          "exclude_globs": []
        }
      ]
    },
    "gallery_lists": {
      "description": "Gallery list assets (csv/xlsx/prompts).",
      "enabled_by_default": false,
      "prune_allowed": false,
      "targets": [
        {
          "local_root": "data/gallery_lists",
          "r2_prefix": "data/gallery_lists",
          "include_globs": [
            "**/*"
          ],
          "exclude_globs": []
        }
      ]
    },
    "docs": {
      "description": "Project docs (optional scope).",
      "enabled_by_default": false,
      "prune_allowed": true,
      "targets": [
        {
          "local_root": "docs",
          "r2_prefix": "docs",
          "include_globs": [
            "**/*"
          ],
          "exclude_globs": []
        }
      ]
    }
  }
}
