{
  "version": "v4",
  "global_exclude_globs": [
    "**/__pycache__/**",
    "**/*.pyc",
    "**/_trial/**",
    "**/_trash/**",
    "**/*.tmp",
    "**/*.bak*",
    "**/Thumbs.db"
  ],
  "scopes": {
    "current_root_mirror": {
      "description": "Primary broad R2 mirror contract. data/current is the source-of-truth for all current families. For app/runtime required RAG integrity audits, use current_required_rag_full.",
      "enabled_by_default": true,
      "sync_mode": "mirror",
      "targets": [
        {
          "local_root": "data/current",
          "r2_prefix": "data/current",
          "include_globs": [
            "**/*"
          ],
          "exclude_globs": []
        }
      ]
    },
    "current_required_rag_full": {
      "description": "Canonical app/runtime current-required RAG parity scope. Mirrors only the current families that runtime resolves directly, including image cache families required for remote hydration.",
      "enabled_by_default": false,
      "sync_mode": "mirror",
      "targets": [
        {
          "name": "raw_artists",
          "local_root": "data/current/raw",
          "r2_prefix": "data/current/raw",
          "include_globs": [
            "artists_*.jsonl"
          ],
          "exclude_globs": []
        },
        {
          "name": "raw_exhibitions",
          "local_root": "data/current/raw",
          "r2_prefix": "data/current/raw",
          "include_globs": [
            "exhibitions_*.jsonl"
          ],
          "exclude_globs": []
        },
        {
          "name": "enrichment_artists_outputs",
          "local_root": "data/current/enrichment",
          "r2_prefix": "data/current/enrichment",
          "include_globs": [
            "artists_enrichment_apply_output*.jsonl"
          ],
          "exclude_globs": []
        },
        {
          "name": "enrichment_exhibitions_outputs",
          "local_root": "data/current/enrichment",
          "r2_prefix": "data/current/enrichment",
          "include_globs": [
            "exhibitions_enrichment_apply_output_*.jsonl"
          ],
          "exclude_globs": []
        },
        {
          "name": "images_metadata_artist_works",
          "local_root": "data/current/images/metadata",
          "r2_prefix": "data/current/images/metadata",
          "include_globs": [
            "artist_works_images_*.jsonl"
          ],
          "exclude_globs": []
        },
        {
          "name": "images_metadata_exhibitions",
          "local_root": "data/current/images/metadata",
          "r2_prefix": "data/current/images/metadata",
          "include_globs": [
            "exhibitions_images_*_*.jsonl"
          ],
          "exclude_globs": []
        },
        {
          "name": "images_cache_artist_works",
          "local_root": "data/current/images/cache/artist_works_images",
          "r2_prefix": "data/current/images/cache/artist_works_images",
          "include_globs": [
            "**/*"
          ],
          "exclude_globs": []
        },
        {
          "name": "images_cache_exhibition_works",
          "local_root": "data/current/images/cache/exhibition_works_images",
          "r2_prefix": "data/current/images/cache/exhibition_works_images",
          "include_globs": [
            "**/*"
          ],
          "exclude_globs": []
        },
        {
          "name": "vector_artists",
          "local_root": "data/current/vector/artists",
          "r2_prefix": "data/current/vector/artists",
          "include_globs": [
            "**/*"
          ],
          "exclude_globs": []
        },
        {
          "name": "vector_artist_works_images",
          "local_root": "data/current/vector/artist_works_images",
          "r2_prefix": "data/current/vector/artist_works_images",
          "include_globs": [
            "**/*"
          ],
          "exclude_globs": []
        }
      ]
    },
    "tarutani_data_retired_mirror": {
      "description": "Explicit retired Tarutani_data cleanup. Deleted local root remains source-of-truth and the remote prefix must converge to empty.",
      "enabled_by_default": false,
      "sync_mode": "mirror",
      "targets": [
        {
          "local_root": "data/Tarutani_data",
          "r2_prefix": "data/Tarutani_data",
          "ignore_global_excludes": true,
          "include_globs": [
            "**/*"
          ],
          "exclude_globs": []
        }
      ]
    },
    "tarutani_legacy_derived_prune": {
      "description": "Explicit retired Tarutani legacy derived cleanup. Remote prefix must converge to empty; uploads are forbidden.",
      "enabled_by_default": false,
      "sync_mode": "prune_only",
      "targets": [
        {
          "local_root": "tarutani/derived",
          "r2_prefix": "tarutani/derived",
          "ignore_global_excludes": true,
          "include_globs": [
            "**/*"
          ],
          "exclude_globs": []
        }
      ]
    },
    "tarutani_legacy_logs_prune": {
      "description": "Explicit retired Tarutani legacy logs cleanup. Remote prefix must converge to empty; uploads are forbidden.",
      "enabled_by_default": false,
      "sync_mode": "prune_only",
      "targets": [
        {
          "local_root": "tarutani/logs",
          "r2_prefix": "tarutani/logs",
          "ignore_global_excludes": true,
          "include_globs": [
            "**/*"
          ],
          "exclude_globs": []
        }
      ]
    },
    "tarutani_legacy_vectors_prune": {
      "description": "Explicit retired Tarutani legacy vectors cleanup. Remote prefix must converge to empty; uploads are forbidden.",
      "enabled_by_default": false,
      "sync_mode": "prune_only",
      "targets": [
        {
          "local_root": "tarutani/vectors",
          "r2_prefix": "tarutani/vectors",
          "ignore_global_excludes": true,
          "include_globs": [
            "**/*"
          ],
          "exclude_globs": []
        }
      ]
    },
    "history_remote_residue_cleanup": {
      "description": "One-time cleanup for R2 history residue. Remote prefix must converge to empty; uploads are forbidden.",
      "enabled_by_default": false,
      "sync_mode": "prune_only",
      "targets": [
        {
          "local_root": "_r2_cleanup/history_remote_empty",
          "r2_prefix": "data/history",
          "ignore_global_excludes": true,
          "include_globs": [
            "**/*"
          ],
          "exclude_globs": []
        }
      ]
    },
    "phase1_seed10_remote_residue_cleanup": {
      "description": "One-time cleanup for legacy R2 phase1_seed10 residue. Remote prefix must converge to empty; uploads are forbidden.",
      "enabled_by_default": false,
      "sync_mode": "prune_only",
      "targets": [
        {
          "local_root": "_r2_cleanup/phase1_seed10_remote_empty",
          "r2_prefix": "phase1_seed10",
          "ignore_global_excludes": true,
          "include_globs": [
            "**/*"
          ],
          "exclude_globs": []
        }
      ]
    },
    "gallery_lists": {
      "description": "Gallery list assets remain optional and upload-only outside the current mirror contract.",
      "enabled_by_default": false,
      "sync_mode": "upload_only",
      "targets": [
        {
          "local_root": "data/gallery_lists",
          "r2_prefix": "data/gallery_lists",
          "include_globs": [
            "**/*"
          ],
          "exclude_globs": []
        }
      ]
    },
    "docs": {
      "description": "Project docs remain optional outside the current mirror contract.",
      "enabled_by_default": false,
      "sync_mode": "mirror",
      "targets": [
        {
          "local_root": "docs",
          "r2_prefix": "docs",
          "include_globs": [
            "**/*"
          ],
          "exclude_globs": []
        }
      ]
    }
  }
}
