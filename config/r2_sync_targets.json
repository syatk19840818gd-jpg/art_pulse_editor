{
  "version": "v3",
  "global_exclude_globs": [
    "**/__pycache__/**",
    "**/*.pyc",
    "**/_trial/**",
    "**/_trash/**",
    "**/*.tmp",
    "**/*.bak*",
    "**/Thumbs.db"
  ],
  "scopes": {
    "current_root_mirror": {
      "description": "Primary and only default R2 mirror contract. data/current is the source-of-truth for all current families.",
      "enabled_by_default": true,
      "sync_mode": "mirror",
      "targets": [
        {
          "local_root": "data/current",
          "r2_prefix": "data/current",
          "include_globs": [
            "**/*"
          ],
          "exclude_globs": []
        }
      ]
    },
    "tarutani_data_retired_mirror": {
      "description": "Explicit retired Tarutani_data cleanup. Deleted local root remains source-of-truth and the remote prefix must converge to empty.",
      "enabled_by_default": false,
      "sync_mode": "mirror",
      "targets": [
        {
          "local_root": "data/Tarutani_data",
          "r2_prefix": "data/Tarutani_data",
          "ignore_global_excludes": true,
          "include_globs": [
            "**/*"
          ],
          "exclude_globs": []
        }
      ]
    },
    "tarutani_legacy_derived_prune": {
      "description": "Explicit retired Tarutani legacy derived cleanup. Remote prefix must converge to empty; uploads are forbidden.",
      "enabled_by_default": false,
      "sync_mode": "prune_only",
      "targets": [
        {
          "local_root": "tarutani/derived",
          "r2_prefix": "tarutani/derived",
          "ignore_global_excludes": true,
          "include_globs": [
            "**/*"
          ],
          "exclude_globs": []
        }
      ]
    },
    "tarutani_legacy_logs_prune": {
      "description": "Explicit retired Tarutani legacy logs cleanup. Remote prefix must converge to empty; uploads are forbidden.",
      "enabled_by_default": false,
      "sync_mode": "prune_only",
      "targets": [
        {
          "local_root": "tarutani/logs",
          "r2_prefix": "tarutani/logs",
          "ignore_global_excludes": true,
          "include_globs": [
            "**/*"
          ],
          "exclude_globs": []
        }
      ]
    },
    "tarutani_legacy_vectors_prune": {
      "description": "Explicit retired Tarutani legacy vectors cleanup. Remote prefix must converge to empty; uploads are forbidden.",
      "enabled_by_default": false,
      "sync_mode": "prune_only",
      "targets": [
        {
          "local_root": "tarutani/vectors",
          "r2_prefix": "tarutani/vectors",
          "ignore_global_excludes": true,
          "include_globs": [
            "**/*"
          ],
          "exclude_globs": []
        }
      ]
    },
    "history_remote_residue_cleanup": {
      "description": "One-time cleanup for R2 history residue. Remote prefix must converge to empty; uploads are forbidden.",
      "enabled_by_default": false,
      "sync_mode": "prune_only",
      "targets": [
        {
          "local_root": "_r2_cleanup/history_remote_empty",
          "r2_prefix": "data/history",
          "ignore_global_excludes": true,
          "include_globs": [
            "**/*"
          ],
          "exclude_globs": []
        }
      ]
    },
    "phase1_seed10_remote_residue_cleanup": {
      "description": "One-time cleanup for legacy R2 phase1_seed10 residue. Remote prefix must converge to empty; uploads are forbidden.",
      "enabled_by_default": false,
      "sync_mode": "prune_only",
      "targets": [
        {
          "local_root": "_r2_cleanup/phase1_seed10_remote_empty",
          "r2_prefix": "phase1_seed10",
          "ignore_global_excludes": true,
          "include_globs": [
            "**/*"
          ],
          "exclude_globs": []
        }
      ]
    },
    "gallery_lists": {
      "description": "Gallery list assets remain optional and upload-only outside the current mirror contract.",
      "enabled_by_default": false,
      "sync_mode": "upload_only",
      "targets": [
        {
          "local_root": "data/gallery_lists",
          "r2_prefix": "data/gallery_lists",
          "include_globs": [
            "**/*"
          ],
          "exclude_globs": []
        }
      ]
    },
    "docs": {
      "description": "Project docs remain optional outside the current mirror contract.",
      "enabled_by_default": false,
      "sync_mode": "mirror",
      "targets": [
        {
          "local_root": "docs",
          "r2_prefix": "docs",
          "include_globs": [
            "**/*"
          ],
          "exclude_globs": []
        }
      ]
    }
  }
}
