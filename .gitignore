############################################################
# ① 絶対にGitに入れない（秘密情報）
############################################################
.env
.env.*
!.env.example
.envrc

############################################################
# ② 仮想環境（環境依存なので入れない）
############################################################
.venv/
venv/
env/
ENV/
.venv_art_pulse_editor

############################################################
# ③ Pythonのキャッシュ（自動生成なので入れない）
############################################################
__pycache__/
*.py[cod]
*$py.class

############################################################
# ④ テスト・カバレッジ（自動生成なので入れない）
############################################################
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
*.py.cover

############################################################
# ⑤ 型チェック・リンター等のキャッシュ（自動生成）
############################################################
.mypy_cache/
.dmypy.json
.pyre/
.pytype/
.ruff_cache/

############################################################
# ⑥ 配布・ビルド成果物（自動生成）
############################################################
build/
dist/
*.egg-info/
.eggs/
wheels/
*.egg
MANIFEST

############################################################
# ⑦ Notebook（自動生成）
############################################################
.ipynb_checkpoints/

############################################################
# ⑧ OSのゴミ
############################################################
.DS_Store
Thumbs.db

############################################################
# ⑨ エディタ設定（基本は入れない）
############################################################
.vscode/

# 共有パターンA：拡張機能のおすすめだけ共有したい時（安全でおすすめ）
#   → ONにする（#を外す）
# !.vscode/extensions.json

# 共有パターンB：プロジェクト設定（フォーマッタ・保存時整形など）も共有したい時
#   → 住所（C:\Users\...等）が入ってないことを確認してからONにする
# !.vscode/settings.json

# ! は 「さっき無視したけど、これは無視しないで！」 “例外解除”の意味

############################################################
# ⑩ その他よくある補助ツール（任意）
############################################################
# Cursor
.cursorignore
.cursorindexingignore

# Jupyter/Colabの一時ファイルなどが出るなら必要に応じて追加
# .cache/
# tmp/.streamlit/secrets.toml
